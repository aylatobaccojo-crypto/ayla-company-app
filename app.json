{
  "expo": {
    "name": "Ayla Company",
    "slug": "ayla-company",
    "owner": "khtar1997",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cashvan",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16213e"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "يحتاج التطبيق لتحديد موقعك لتتبع الفان وعرضه للمدير",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "يحتاج التطبيق لتحديد موقعك لتتبع الفان"
      }
    },
    "android": {
      "package": "com.ayla.cashvan",
      "versionCode": 5,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يحتاج التطبيق لتحديد موقعك لتتبع الفان"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1d6ae8",
          "sounds": [],
          "androidCollapsedTitle": "رسائل جديدة"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "01bbe857-2fb2-4bb1-85c8-84fb5ba1de24"
      }
    }
  }
}
